# Copy to .env and fill in. .env is gitignored.

# ── PCC API ────────────────────────────────────────────────────────────
PCC_API_BASE_URL=https://hackathon.prod.pulsefoundry.ai

# ── Postgres ───────────────────────────────────────────────────────────
POSTGRES_USER=woundiq
POSTGRES_PASSWORD=woundiq_dev_only
POSTGRES_DB=woundiq
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
# Async URL used by SQLAlchemy + Alembic at runtime
DATABASE_URL=postgresql+asyncpg://woundiq:woundiq_dev_only@postgres:5432/woundiq
# Sync URL used by Alembic migrations (psycopg2)
DATABASE_URL_SYNC=postgresql://woundiq:woundiq_dev_only@postgres:5432/woundiq

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Prefect ────────────────────────────────────────────────────────────
PREFECT_API_URL=http://prefect:4200/api

# ── Baseten (LLM extraction) ───────────────────────────────────────────
BASETEN_API_KEY=replace_me
BASETEN_MODEL_ID_SMALL=replace_me
BASETEN_MODEL_ID_LARGE=replace_me

# ── 11Labs (voice copilot) ─────────────────────────────────────────────
ELEVENLABS_API_KEY=replace_me
ELEVENLABS_VOICE_ID=replace_me

# ── App config ─────────────────────────────────────────────────────────
ORG_ID=ORG-DEMO
LOG_LEVEL=INFO
ENV=local

# ── Next.js ────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
